	"private": true,
	"license": "GPL-3.0 license",
	"type": "module",
	"scripts": {
		"build": "nuxt build",
		"dev": "nuxt dev",
		"format": "prettier --write \"{components,pages,plugins,middleware,layouts,composables,assets}/**/*.vue\" \"*.vue\"",
		"generate": "nuxt generate",
		"lint": "eslint *.vue --fix",
